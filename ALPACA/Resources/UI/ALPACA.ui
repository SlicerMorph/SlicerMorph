             <double>100.000000000000000</double>
            </property>
           </widget>
          </item>
          <item row="3" column="0">
           <widget class="QLabel" name="CPDToleranceLabel">
            <property name="text">
             <string>CPD tolerance:</string>
            </property>
           </widget>
          </item>
          <item row="3" column="1">
           <widget class="ctkSliderWidget" name="CPDToleranceSlider" native="true">
            <property name="toolTip">
             <string>Tolerance used to assess CPD convergence</string>
            </property>
            <property name="decimals" stdset="0">
             <number>4</number>
            </property>
            <property name="singleStep" stdset="0">
             <double>0.000100000000000</double>
            </property>
            <property name="minimum" stdset="0">
             <double>0.000100000000000</double>
            </property>
            <property name="maximum" stdset="0">
             <double>0.010000000000000</double>
            </property>
            <property name="value" stdset="0">
             <double>0.001000000000000</double>
            </property>
           </widget>
          </item>
          <item row="4" column="0">
           <widget class="QLabel" name="accelerationLabel">
            <property name="text">
             <string>Acceleration</string>
            </property>
           </widget>
          </item>
          <item row="4" column="1">
           <widget class="QCheckBox" name="accelerationCheckBox">
            <property name="toolTip">
             <string>If checked, ALPACA will accelerate the deformable step using VBI.</string>
            </property>
           </widget>
          </item>
          <item row="5" column="0">
           <widget class="QLabel" name="BCPDFolderLabel">
            <property name="text">
             <string>BCPD directory:</string>
            </property>
           </widget>
          </item>
          <item row="5" column="1">
           <widget class="ctkPathLineEdit" name="BCPDFolder" native="true">
            <property name="toolTip">
             <string>Select the directory of containing the compiled BCPD</string>
            </property>
            <property name="filters">
