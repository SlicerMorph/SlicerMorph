            </property>
            <property name="singleStep" stdset="0">
             <double>0.050000000000000</double>
            </property>
            <property name="value" stdset="0">
             <double>2.000000000000000</double>
            </property>
           </widget>
          </item>
          <item row="1" column="0">
           <widget class="QLabel" name="betaLabel">
            <property name="text">
             <string>Motion coherence (beta):</string>
            </property>
           </widget>
          </item>
          <item row="1" column="1">
           <widget class="ctkDoubleSpinBox" name="beta" native="true">
            <property name="toolTip">
             <string>Width of gaussian filter used when applying smoothness constraint</string>
            </property>
            <property name="decimals" stdset="0">
             <number>1</number>
            </property>
            <property name="minimum" stdset="0">
             <double>0.010000000000000</double>
            </property>
            <property name="maximum" stdset="0">
             <double>100.000000000000000</double>
            </property>
            <property name="singleStep" stdset="0">
             <double>0.050000000000000</double>
            </property>
            <property name="value" stdset="0">
             <double>2.000000000000000</double>
            </property>
           </widget>
          </item>
          <item row="2" column="0">
           <widget class="QLabel" name="CPDIterationsLabel">
