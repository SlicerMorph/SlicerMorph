        </widget>
       </item>
       <item>
        <widget class="ctkCollapsibleButton" name="deformableRegistrationWidget" native="true">
         <property name="sizePolicy">
          <sizepolicy hsizetype="Minimum" vsizetype="MinimumExpanding">
           <horstretch>0</horstretch>
           <verstretch>0</verstretch>
          </sizepolicy>
         </property>
         <property name="text" stdset="0">
          <string>Deformable registration</string>
         </property>
         <property name="collapsed" stdset="0">
          <bool>false</bool>
         </property>
         <layout class="QFormLayout" name="deformableRegistrationWidgetLayout">
          <item row="0" column="0">
           <widget class="QLabel" name="alphaLabel">
            <property name="text">
             <string>Rigidity (alpha):</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <widget class="ctkDoubleSpinBox" name="alpha" native="true">
            <property name="toolTip">
             <string>Parameter specifying trade-off between fit and smoothness. Low values induce fluidity, while higher values impose rigidity</string>
            </property>
            <property name="decimals" stdset="0">
             <number>1</number>
            </property>
            <property name="minimum" stdset="0">
             <double>0.010000000000000</double>
            </property>
